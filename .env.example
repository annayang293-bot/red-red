SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
OPENAI_API_KEY=sk-...
# Apify API token for the harshmaur/reddit-scraper actor (Reddit listing + comments).
# Get one at https://console.apify.com/account/integrations after signing in.
# Required when pipeline.reddit.auth_mode == "apify" (the default since 2026-05-31).
# Without this, cron / on-demand pipeline runs go red (degraded exit 1 from run_once.py).
APIFY_TOKEN=apify_api_xxx
